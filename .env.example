# ========================================
# Discord設定（Discord使う場合）
# ========================================
DISCORD_TOKEN=your_discord_bot_token_here

# ========================================
# 許可ユーザー設定（必須）
# ========================================
# Discord用（カンマ区切りで複数指定可、"*" で全員許可）
DISCORD_ALLOWED_USER=your_discord_user_id_here
# 複数ユーザー例: DISCORD_ALLOWED_USER=123456789,987654321
# 全員許可: DISCORD_ALLOWED_USER=*

# Slack用（カンマ区切りで複数指定可、"*" で全員許可）
# SLACK_ALLOWED_USER=your_slack_user_id_here

# ========================================
# AIエージェント設定
# ========================================
# Agent backend: claude-code, codex, cursor, grok, antigravity, local-llm (default: codex)
AGENT_BACKEND=codex

# Optional: Model to use (backend-specific)
# AGENT_MODEL=

# Claude Code backend (AGENT_BACKEND=claude-code)
# ANTHROPIC_API_KEY is passed only to the Claude Code child process.
# Set CLAUDE_CODE_BARE=true to force Anthropic API-key auth instead of OAuth/keychain.
# CLAUDE_CODE_MAX_BUDGET_USD limits API spend per Claude Code print-mode run.
# ANTHROPIC_API_KEY=
# CLAUDE_CODE_BARE=false
# CLAUDE_CODE_MAX_BUDGET_USD=

# Cursor CLI backend (AGENT_BACKEND=cursor)
# Cursor CLI trust/force are enabled by default for non-interactive xangi runs
# after you trust the workspace. Set them to false to disable.
# CURSOR_API_KEY=
# CURSOR_TRUST_WORKSPACE=false
# CURSOR_FORCE=false

# Antigravity CLI backend (AGENT_BACKEND=antigravity)
# Timeout passed to `agy --print-timeout` (Go duration format).
# ANTIGRAVITY_PRINT_TIMEOUT=5m

# 切り替え許可バックエンド（カンマ区切り、未設定=全バックエンド許可）
# ALLOWED_BACKENDS=claude-code,codex,cursor,grok,antigravity,local-llm

# 切り替え許可モデル（カンマ区切り、未設定=制限なし）
# ALLOWED_MODELS=nemotron-3-nano,nemotron-3-super,qwen3.5:9b

# チャンネル別バックエンド設定（JSON、/model setの初期値）
# CHANNEL_OVERRIDES={"チャンネルID":{"backend":"local-llm","model":"nemotron-3-nano"}}
# Local LLM の動作モードもチャンネル別に切替可能（agent/lite/chat）
# CHANNEL_OVERRIDES={"channel_id":{"backend":"local-llm","localLlmMode":"agent"},"other_id":{"backend":"local-llm","localLlmMode":"lite"}}

# /llmmode slash command を有効化（デフォルト ON）
# Discord で /llmmode <agent|lite|chat|default|show> を許可するか
# ALLOW_LLM_MODE_COMMAND=true

# ========================================
# ワークスペース設定
# ========================================
# Optional: Workspace path for agent (default: ./workspace)
# WORKSPACE_PATH=/path/to/your/workspace

# Optional: Data storage directory for schedules, sessions, etc. (default: WORKSPACE_PATH/.xangi)
# DATA_DIR=/path/to/data/dir

# Docker用: ホストのワークスペースパス（docker-compose.ymlのvolumeマウント用）
# ホスト環境変数との衝突を避けるためWORKSPACE_PATHとは別名
# XANGI_WORKSPACE=/path/to/your/workspace

# Optional: Channels where bot responds without mention (comma-separated)
# AUTO_REPLY_CHANNELS=123456789,987654321

# Optional: Allow /autoreply command to toggle auto-reply from Discord (default: true)
# ALLOW_AUTOREPLY_COMMAND=true

# Optional: Whitelist of other bot IDs whose messages this bot may respond to.
#   Empty (default) = no bot is targeted
#   "*" = target all bots
#   "<bot_id_1>,<bot_id_2>" = target only listed bots
# Bot's own ID is always excluded to avoid infinite loops.
# Use case: A/B compare responses across xangi instances (e.g. xangi-borot=Claude vs xangi-dev=Local LLM).
# Actual ON/OFF is controlled by RESPOND_TO_BOTS_ENABLED below.
# RESPOND_TO_BOTS=

# Optional: Enable bot-message response feature (default: false)
# Toggle from Discord with /respondtobots command (persists back to this file).
# RESPOND_TO_BOTS_ENABLED=false

# Optional: Max consecutive responses to the SAME bot before bailing out (default: 3, 0 = unlimited).
# Resets when a human or a different bot posts. Safety net against runaway bot-bot loops.
# RESPOND_TO_BOTS_MAX_CONSECUTIVE=3

# Optional: Allow /respondtobots command to toggle the bot-response feature from Discord (default: true)
# ALLOW_RESPOND_TO_BOTS_COMMAND=true

# Optional: Streaming output (default: true)
# DISCORD_STREAMING=true

# Optional: Show thinking process (default: true, false shows "考え中..." animation)
# DISCORD_SHOW_THINKING=true

# Optional: Show Stop/New Session buttons on messages (default: true)
# DISCORD_SHOW_BUTTONS=true

# Optional: Discord tool-use history display mode (default: button)
# button: 通常メッセージには出さず Tools ボタンで本人だけに表示
# inline: 通常メッセージ本文に `🔧 Bash...` などを表示
# off: ツール利用履歴を表示しない
# DISCORD_TOOL_HISTORY_MODE=button
# Optional: Show the Tools button when DISCORD_TOOL_HISTORY_MODE=button (default: true)
# DISCORD_SHOW_TOOL_BUTTON=true
# Optional: Show raw tool commands while running (default: true)
# DISCORD_SHOW_LIVE_TOOL_USE=true
# Legacy: false は DISCORD_TOOL_HISTORY_MODE=off、true は inline として扱います。
# DISCORD_SHOW_TOOL_USE=false

# Optional: Send a separate completion notification after long Discord turns (default: message)
# off: 通知なし（従来通り最終返信を edit）
# message: 完了メッセージだけ送る
# mention: 依頼者に mention 付きで完了通知を送る
# 起動時のデフォルト値。チャンネル別の上書きは /notify で settings.json に保存。
# 対象は通常の Discord メッセージターンのみ（スケジュール起点ターンは通知なし）。
# DISCORD_COMPLETION_NOTIFY=message
# Optional: Minimum elapsed time before completion notification is sent (default: 10000 = 10s)
# DISCORD_COMPLETION_NOTIFY_AFTER_MS=10000

# Optional: Inject channel topic into prompt (default: true)
# INJECT_CHANNEL_TOPIC=true

# Optional: Inject current timestamp into prompt (default: true)
# INJECT_TIMESTAMP=true

# Optional: Tool call display max length in chat (chars, default: 200)
# Bash/exec ツール呼び出しの引数表示の最大文字数。
# `codex exec "..."` のような長いラッパーコマンド全文を見たいときに増やす。
# XANGI_TOOL_DISPLAY_MAX=200

# Optional: Tool history display max lines (default: 10, <=0 for unlimited)
# ツール履歴表示の最大行数。超過分は先頭に「… (+N 件省略)」とまとめて最新行だけ表示する。
# TOOL_HISTORY_MAX_LINES=10

# Optional: Runtime context (cwd / repo) injection (default: true)
# 各ターンの prompt 先頭に `[runtime] cwd=... repo=name@branch` を注入し、
# AI が借りリポと本体リポを取り違えて push する事故を構造的に減らす。
# false / 0 / off にすると注入をオフにできる（雑談のみのインスタンス等）。
# XANGI_RUNTIME_CONTEXT_ENABLED=true

# ========================================
# Slack設定（Slack使う場合）
# ========================================
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token

# Optional: Slack channels where bot responds without mention
# SLACK_AUTO_REPLY_CHANNELS=C01234567,C89012345

# Optional: Reply in channel instead of thread (default: true = thread)
# SLACK_REPLY_IN_THREAD=false

# Optional: Slack channel IDs where replies are posted to the channel instead of threads
# SLACK_REPLY_IN_CHANNELS=C01234567,C89012345

# Optional: Streaming output (default: true)
# SLACK_STREAMING=true

# Optional: Show thinking process (default: true)
# SLACK_SHOW_THINKING=true

# ========================================
# LINE Messaging API 設定（LINE Bot として使う場合）
# ========================================
# LINE Developers コンソール (https://developers.line.biz/) でプロバイダーと
# Messaging API channel を作成し、以下を取得して設定する:
#   - Channel access token (long-lived)  → LINE_CHANNEL_ACCESS_TOKEN
#   - Channel secret                     → LINE_CHANNEL_SECRET
# Webhook URL は Tailscale Funnel / Cloudflare Tunnel 等で公開した
# `https://<host>/webhook` (LINE_WEBHOOK_PATH に従う) を LINE 側に登録する。

# LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
# LINE_CHANNEL_SECRET=your_line_channel_secret

# 必須: 反応する LINE userId のホワイトリスト (カンマ区切り、"*" で全許可)
# 1:1 chat 想定なので、デフォルトは「特定ユーザのみ」を推奨。
# 友だち追加して話しかけた時にログに表示される userId を控えて設定する。
# LINE_ALLOWED_USER=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Webhook を受ける HTTP サーバのポート (default: 8765)
# Tailscale Funnel は 443 / 8443 / 10000 のみ転送可能なので、
# 内部ポートはそのまま 8765 で、Funnel 側で 443 → 8765 のマッピングを設定する。
# LINE_WEBHOOK_PORT=8765

# Optional: Webhook を受けるパス (default: /webhook)
# LINE Developers コンソールに登録する URL の末尾と合わせる。
# LINE_WEBHOOK_PATH=/webhook

# Optional: Loading animation (即時 ACK) を有効にするか (default: true)
# webhook 受信直後に「入力中…」アニメをトーク画面に表示する。1:1 DM のみ機能。
# 受け取った瞬間に視覚的反応を出して「無視された」感を防ぐ。
# LINE_LOADING_ANIMATION_ENABLED=true

# Optional: Loading animation の表示秒数 (5/10/15/20/25/30/40/50/60、default: 60)
# Bot から新メッセージを送ると自動消滅。LINE 仕様で 5 の倍数・最大 60。
# 範囲外を指定すると最寄りの valid 値にスナップされる。
# LINE_LOADING_ANIMATION_SECONDS=60

# Optional: Reply→Push 自動切替を有効にするか (default: true)
# LINE の reply token は 60s で失効するため、応答に時間がかかった時は
# 一旦 reply token で「考え中」を送って token 消費、本回答を Push API で
# 後追い送信する。無効にすると 60s 超応答は完全に失われる。
# LINE_SLOW_RESPONSE_ENABLED=true

# Optional: Slow response 閾値 ms (default: 45000 = 45秒)
# これを超えた時点で「考え中」テンプレを reply token で送り、本回答は Push API で送る。
# LINE reply token の失効 (60s) に対する安全マージンとして 45s が default。
# Push API は個人 OA で月 200 通無料、超過後は従量課金になる点に注意。
# LINE_SLOW_RESPONSE_THRESHOLD_MS=45000

# Optional: Idle session reset を有効にするか (default: true)
# LINE は Slack スレッド / Discord New ボタンのような UI 境界が無いため、
# 一定時間黙ったら次の発話で session を自動切替する (会話履歴は jsonl に残る)。
# 学校・就寝・食事クラスタを自然に分けるための時間ベース session 境界。
# LINE_IDLE_RESET_ENABLED=true

# Optional: Idle reset の閾値時間 (default: 4)
# 直前の発話から N 時間以上経過していたら、新メッセージ到着時に既存 session を
# archive して新規発番する。小数可 (例: 0.5 = 30 分)。0 以下で無効化。
# LINE_IDLE_RESET_HOURS=4

# Optional: Reset コマンドのテキストパターン (CSV、default: /reset,/new,/clear)
# ユーザがこれらのフレーズを送ると session を archive + 新規発番し、Runner は
# 起動せず「最初からお話するね」と即返す。完全一致 (大文字小文字無視、前後空白 strip)。
# メイン境界は idle reset (時間ベース) なので、コマンドは曖昧さの無い slash 3 つに絞る default。
# 日本語自然言語パターンが欲しい場合は明示追加 (例: LINE_RESET_TEXT_PATTERNS=/reset,/new,/clear,リセット,最初から)。
# 空文字列で検出無効化 (LINE_RESET_TEXT_PATTERNS=)。
# LINE_RESET_TEXT_PATTERNS=/reset,/new,/clear,リセット,最初から

# ========================================
# Telegram設定（Telegram使う場合）
# ========================================
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_MODE=polling
# TELEGRAM_FORCE_IPV4=false  # api.telegram.org の IPv6 経路が不安定な場合のみ true
# TELEGRAM_WEBHOOK_PORT=8766
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET_TOKEN=
# TELEGRAM_WEBHOOK_URL=https://your-host.example.com  # webhook mode 時に setWebhook で自動登録する公開URL
# TELEGRAM_STREAMING=true
# TELEGRAM_SHOW_THINKING=true
# TELEGRAM_REPLY_TO_MENTION_IN_GROUP=true
# TELEGRAM_IDLE_RESET_ENABLED=true
# TELEGRAM_IDLE_RESET_HOURS=4
# TELEGRAM_RESET_TEXT_PATTERNS=/reset,/new,/clear

# 必須: 反応するTelegram user ID（カンマ区切り、"*" で全許可）
# TELEGRAM_ALLOWED_USER=your_telegram_user_id_here

# Optional: 許可Bot・グループChat ID（CSV）
# TELEGRAM_ALLOWED_BOTS=your_allowed_bot_id_1,your_allowed_bot_id_2
# TELEGRAM_ALLOWED_CHATS=your_telegram_chat_id_here
# TELEGRAM_AUTO_REPLY_CHATS=your_auto_reply_chat_id_here
# TELEGRAM_ALLOWED_BOTS_MAX_CONSECUTIVE=3

# ========================================

# ツール承認設定
# ========================================
# 危険コマンド実行前にDiscord/Slackで承認を求める（default: false）
# APPROVAL_ENABLED=false

# 承認サーバーのポート（default: 18181）
# APPROVAL_SERVER_PORT=18181

# ========================================
# Local LLM設定（AGENT_BACKEND=local-llm の場合）
# ========================================
# LLMサーバーのURL
# ローカル実行: http://localhost:11434（デフォルト）
# Docker実行: http://ollama-proxy:11434（デフォルト、プロキシ経由でホストのOllamaに接続）
# LOCAL_LLM_BASE_URL=http://localhost:11434

# 使用するモデル名
# LOCAL_LLM_MODEL=nemotron-3-nano

# APIキー（vLLM等でAPIキーが必要な場合）
# LOCAL_LLM_API_KEY=

# Thinkingモデルの推論を有効にするか（default: false）
# 有効にすると Ollama の native thinking ブロックが出る代わりに応答が大幅に遅くなる
# LOCAL_LLM_THINKING=false

# 最大トークン数（default: 8192）
# LOCAL_LLM_MAX_TOKENS=8192

# コンテキストウィンドウサイズ（Ollama num_ctx、default: モデルのデフォルト値）
# 推奨: 131072 — arxiv 全文 (~70k tokens) や site-patrol の長いプロンプトを安定処理可
# 32768 では tool 1 個呼んだ瞬間 overflow、65536 でも論文全文読解は入らず深掘り解説不可
# 未指定だとモデル最大値（例: 262144）が使われて遅くなるので明示推奨
# vLLM 利用時は server 側も `--max-model-len 131072 --kv-cache-dtype fp8 --gpu-memory-utilization 0.85` を揃えること
# LOCAL_LLM_NUM_CTX=131072

# サンプリング温度（default: モデルデフォルト = 1.0）
# 0 を指定すると決定的（agent モードで format drift を抑えたい時に有効）
# LOCAL_LLM_TEMPERATURE=0.7

# Local LLMの機能を個別にon/off（デフォルト全てtrue）
# LOCAL_LLM_TOOLS=true            # ツール実行（exec/read/write/edit/glob/grep/web_fetch）
# LOCAL_LLM_SKILLS=true           # スキル一覧注入
# LOCAL_LLM_XANGI_COMMANDS=true   # XANGI_COMMANDS注入
# LOCAL_LLM_TRIGGERS=false        # トリガー（!コマンド）

# プリセット（個別設定がない項目のデフォルトを変更）
# LOCAL_LLM_MODE=agent   # agent: 全部on / chat: 全部off / lite: triggers only

# ----------------------------------------
# Tool 遅延ロード (Codex / Claude Code 流の tool_search)
# ----------------------------------------
# tool_search 機能の有効化（default: true）
# 有効時: builtin core (read/write/edit/exec/glob/grep/send_file/web_fetch) + tool_search を常駐、
#         残りの xangi-tools / triggers は deferred（tool_search 経由で呼び出す）
# 無効化すると全 tool が常駐に戻る（従来挙動）
# LOCAL_LLM_TOOL_SEARCH_ENABLED=true

# tool_search が 1 回で返す最大ツール数 (default: 8)
# LOCAL_LLM_TOOL_SEARCH_LIMIT=8

# 常駐 tool 名（カンマ区切り）。ここに無い tool は deferred 扱い
# default: read,write,edit,exec,glob,grep,send_file,web_fetch,tool_search
# tool_search は無条件で含まれる（deferred tool 呼び出しの入口）
# 例: builtin core 全部に xangi の discord_send だけ常駐させたい場合
# LOCAL_LLM_ALWAYS_LOADED_TOOLS=read,write,edit,exec,glob,grep,send_file,web_fetch,discord_send

# ----------------------------------------
# Context budget（履歴刈り込み設定）
# ----------------------------------------
# 明示指定（最優先、未指定なら NUM_CTX から逆算される）
# 文字数ベース、1 token ≒ 3 chars 想定（日本語混じり保守側）
# LOCAL_LLM_CONTEXT_MAX_CHARS=60000

# 逆算用バジェット（明示 LOCAL_LLM_CONTEXT_MAX_CHARS 未指定時に使われる）
# 計算式: contextMaxChars = (NUM_CTX - SYSTEM - OUTPUT - SAFETY) * 3
# 例: NUM_CTX=32768, SYSTEM=8000, OUTPUT=4096, SAFETY=1000 → 19672 tokens → 59016 chars
# LOCAL_LLM_SYSTEM_PROMPT_BUDGET_TOKENS=8000   # system prompt が占める想定トークン数
# LOCAL_LLM_OUTPUT_BUDGET_TOKENS=4096          # 1 リクエストの最大出力トークン
# LOCAL_LLM_SAFETY_MARGIN_TOKENS=1000          # 安全マージン

# 直近何件のメッセージは削除しない（default: 10）
# LOCAL_LLM_CONTEXT_KEEP_LAST=10

# tool 結果の最大文字数（コンテキスト内での切り詰め、default: 4000）
# LOCAL_LLM_TOOL_RESULT_MAX_CHARS=4000

# セッションの最大メッセージ数（default: 50、超えたら古いものから削除）
# LOCAL_LLM_MAX_SESSION_MESSAGES=50

# execツールのタイムアウト（ミリ秒、default: 120000 = 2min）
# 画像生成等の時間がかかるコマンド用に長めに設定
# EXEC_TIMEOUT_MS=120000

# web_fetchツールのタイムアウト（ミリ秒、default: 15000）
# WEB_FETCH_TIMEOUT_MS=15000

# read/writeツールのファイルサイズ上限（バイト、default: 524288 = 512KB）
# LOCAL_LLM_READ_MAX_BYTES=524288
# LOCAL_LLM_WRITE_MAX_BYTES=524288

# readツールでJSONファイルを読むときの上限（バイト、default: 5120 = 5KB）
# 大きいJSONはCLIツール経由のクエリを推奨するため意図的に小さい
# LOCAL_LLM_READ_JSON_MAX_BYTES=5120

# Optional: Agent initial timeout in milliseconds (default: 1800000 = 30min)
# TIMEOUT_MS=1800000

# Optional: Session retention in days (default: 0 = keep forever)
# 日数を設定すると sessions.json の古いセッション（updatedAt 基準）を起動時に剪定する
# XANGI_SESSION_RETENTION_DAYS=90

# Optional: Fixed port for the internal tool server (default: reuse last port, or auto-assign)
# 再起動でポートが変わると resume されたセッションの XANGI_TOOL_SERVER が古くなるため、
# 既定で前回ポートを再利用する。固定したい場合はここで指定。
# XANGI_TOOL_SERVER_PORT=18790

# Optional: Event trigger — start an agent turn from external events (default: disabled)
# 外部イベント（ビルド完了・CI 結果等）から POST /api/trigger でエージェントターンを起動する。
# XANGI_TRIGGER_TOKEN は必須（未設定だと有効化しても HTTP 経由は全拒否）。
# TRIGGER_ENABLED=true
# XANGI_TRIGGER_TOKEN=
# TRIGGER_MIN_INTERVAL_MS=10000

# Optional: Treat invalid environment values as startup errors (default: false)
# false (default): 不正な値は警告してデフォルト値にフォールバックして起動を続行
# true: 不正な値があると起動を中断する（typo の早期発見向け）
# XANGI_CONFIG_STRICT=false

# Optional: Absolute upper limit for timeout extension (default: 3600000 = 1h)
# 数時間動かしっぱなしのタスクを許容したい場合は、ここを大きくする。
# 例: 6 時間まで延長可能にする
# TIMEOUT_MAX_MS=21600000

# Optional: Enable / disable the timeout extension button (default: true)
# false にすると [延長] ボタンが UI から消え、extendTimeout API が unsupported を返す。
# TIMEOUT_EXTEND_ENABLED=true

# Optional: Skip permissions by default (true/false, default: true)
# Discord/Slack/Web チャット連携は非対話実行のため、デフォルトで AI の許可確認を
# スキップする（permission プロンプトに答える人間がいないとタスクが永久に待ち状態になる）。
# 信頼できないワークスペースやマルチユーザー環境で許可確認を有効化したいときは
# 明示的に false を指定する。
# SKIP_PERMISSIONS=false

# ========================================
# プロセス管理設定
# ========================================
# Optional: Persistent process mode (default: true)
# PERSISTENT_MODE=true

# Optional: Maximum concurrent processes (default: 10)
# MAX_PROCESSES=10

# Optional: Auto-terminate idle processes after ms (default: 1800000 = 30min)
# IDLE_TIMEOUT_MS=1800000

# ========================================
# GitHub App認証（オプション、設定するとgh CLIにAppトークンを自動注入）
# ========================================
# 設定しなければ従来のgh認証（gh auth login / GH_TOKEN）をそのまま使用
# GITHUB_APP_ID=1234567
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem

# ========================================
# WebチャットUI設定
# ========================================
# Optional: Enable Web Chat UI (default: disabled)
# Discord/Slack 不要でブラウザだけで使いたい場合は有効化。http://localhost:18888 に UI を公開する。
# WEB_CHAT_ENABLED=true

# Optional: Web Chat UI port (default: 18888)
# WEB_CHAT_PORT=18888

# Optional: Web Chat ファイルアップロード許可リスト
# 未設定なら全ての拡張子 / MIME を許可 (デフォルト)。
# 値は HTML <input accept> 属性にそのまま使われる。
# 加えて、`.ext` で始まるエントリはサーバ側でも拡張子検証に使われる
# (MIME パターン `image/*` などはフロント側のヒントとしてのみ機能)。
# 例: 画像 + PDF + 音声系のみ許可する
# WEB_CHAT_UPLOAD_ACCEPT=image/*,.pdf,.mp3,.m4a,.wav,.ogg,.flac

# Optional: Web Chat ファイルダウンロード許可リスト
# 未設定なら全ての拡張子を許可 (デフォルト)。
# 設定時は `.ext` で始まるエントリのみがサーバ側で拡張子検証に使われる。
# 既知の MIME (html/css/js/json/txt/md/csv/xml/yaml/zip/png/jpg/.../mp3/.../pdf 等) は
# 適切な Content-Type で inline 配信、それ以外は Content-Disposition: attachment で
# ファイル名付きダウンロードとして配信される (LLM 生成の任意拡張子ファイルも開ける)。
# 例: HTML + テキスト系 + 画像のみ許可する
# WEB_CHAT_DOWNLOAD_ACCEPT=.html,.txt,.md,.json,.png,.jpg,.gif

# Optional: 応答テキストからの添付抽出 (MEDIA: / [IMAGE:] / 裸パス) で
# 添付を許可する追加ディレクトリ (カンマ区切り絶対パス)。
# デフォルトの許可先は WORKSPACE_PATH 配下・添付保存先 (.xangi/media/attachments)・/tmp。
# 生成物を WORKSPACE 外の固定ディレクトリに吐く運用のときだけ追加する。
# realpath 解決後に startsWith 判定するので、ここに無いパス (例: /etc/...) は添付されない。
# 例: ATTACHMENT_ALLOWED_DIRS=/data/generated,/mnt/outputs
# ATTACHMENT_ALLOWED_DIRS=

# ========================================
# スケジューラ設定
# ========================================
# Optional: Enable/disable scheduler (cron/once jobs) (default: true)
# Set to false when running multiple instances to avoid duplicate execution
# SCHEDULER_ENABLED=true

# Optional: Enable/disable startup tasks (default: true)
# Set to false when running multiple instances to avoid duplicate execution
# STARTUP_ENABLED=true

# ========================================
# 外部イベントストリーム設定（オプション）
# ========================================
# xangi の応答ライフサイクル（turn.started / message.delta / turn.complete /
# turn.aborted / agent.error）を pull 型 SSE で外部に配信する。
# consumer (デスクトップアバター・可視化ツール等) は web-chat サーバの
#   GET /api/events/stream
# に接続して取りに来る。詳細は docs/events.md を参照。

# Optional: Disable event emission entirely (default: true)
# false にすると /api/events/stream は 503 を返す。
# XANGI_EVENTS_ENABLED=false

# Even Terminal compatibility API (Even Realities G2 terminal mode)
# 公式 Even Terminal アプリ互換の /api/prompt / /api/events / /api/sessions 等を有効にする。
# Server URL は Web Chat と同じ URL（例: http://<tailscale-ip>:18889）、Even 側の provider
# 選択 (Claude Code / Codex) は UI 互換ラベルとして扱われる。
# 実 backend は AGENT_BACKEND で決まるが、Even Terminal 経由だけ別 default にしたい場合は
# XANGI_EVEN_TERMINAL_BACKEND / MODEL / LOCAL_LLM_MODE を設定する。
#
# 公開 URL / Tailscale Funnel / Cloudflare Tunnel で使う場合は必ず token を設定する。
# 未設定時は XANGI_DEVICE_INBOX_TOKEN → XANGI_PET_INBOX_TOKEN に fallback する。
# XANGI_EVEN_TERMINAL_TOKEN=your-even-terminal-secret
#
# Optional: Even Terminal 経由だけの backend/model/Local LLM mode default。
# CHANNEL_OVERRIDES に `web-chat:<sessionId>` がある場合はそちらが優先される。
# XANGI_EVEN_TERMINAL_BACKEND=local-llm
# XANGI_EVEN_TERMINAL_MODEL=gemma-4-26b-a4b
# XANGI_EVEN_TERMINAL_LOCAL_LLM_MODE=chat
#
# G2 の表示向けに text_delta/result/history の Markdown を落として短くする最大文字数。
# XANGI_EVEN_TERMINAL_MAX_CHARS=400

# Optional: Instance identifier for event filtering (default: xangi-<hostname>-<DATA_DIR hash>)
# 同じ consumer に複数の xangi を繋ぐときに consumer 側でフィルタするために使う。
# 未指定なら DATA_DIR から自動採番される（同じ DATA_DIR で再起動すれば同じ ID）。
# 複数インスタンス運用なら明示指定推奨。inter-instance-chat とも共通の ID。
# XANGI_INSTANCE_ID=xangi-prod

# Optional: Display label for inter-instance-chat / web UI (default: same as XANGI_INSTANCE_ID)
# XANGI_INSTANCE_LABEL=my-instance

# Pet inbox: consumer 側 UI (xangi-pet 等) からテキストを 1 行投げ込む書き込み API。
# 受理されたら 202 が即返り、応答は既存の /api/events/stream 経由で broadcast される。
# 詳細は docs/events.md の「Pet からの入力経路」セクション。
# false で完全に無効化 (POST /api/pet/inbox が 503 を返す)。
# XANGI_PET_INBOX_ENABLED=false
#
# Device inbox: 外部デバイス向けの `/api/device/inbox` と `/api/terminal/inbox`。
# false で device/terminal 書き込み経路だけを無効化する。
# 未設定時は XANGI_PET_INBOX_ENABLED に従う。
# XANGI_DEVICE_INBOX_ENABLED=false

# token 設定時は Authorization: Bearer <token> 必須。
# 未設定時のデフォルト挙動:
# - 許可: loopback (127.0.0.0/8 / ::1) + RFC1918 LAN + Tailscale (CGNAT 100.64/10)
#   + IPv6 link-local / ULA
# - 拒否: 上記以外のグローバル IP (Cloudflare Tunnel 等でパブリック公開してる場合)
# 自宅 LAN や Tailscale で運用してれば設定ゼロでも pet からテキスト送れる。
# グローバル IP に xangi を晒してる人だけ token を設定。
# XANGI_PET_INBOX_TOKEN=your-shared-secret
#
# Device/terminal 用 token。未設定時は XANGI_PET_INBOX_TOKEN に fallback する。
# XANGI_DEVICE_INBOX_TOKEN=your-device-shared-secret

# Optional: Override the .env file path used for runtime write-back
# (used by /autoreply, /respondtobots, /backend slash commands etc.)
#
# 設定の持続には 2 層ある。混同に注意:
#
# 層 1 (常に有効、書き換え不要): このファイル (.env) の初期値は env_file
#   ディレクティブ経由で env vars として container に注入される。AUTO_REPLY_CHANNELS=
#   等の初期値は Docker でも再起動でも自動的に反映される。本番設定変更はこのファイルを
#   編集 + container 再起動が正規ルート。
#
# 層 2 (slash command で動的書き戻し、Docker default では skip):
#   /autoreply 等でメモリ上の設定を動的に切り替えたとき、その変更を .env に書き戻すか。
#   - ローカル直接実行: process.cwd()/.env を書き換える (再起動後も維持)
#   - Docker: /app/.env が存在しないため書き戻し失敗、メモリのみの変更で再起動で
#     層 1 の初期値に戻る (チャット経由でイメージ層を書き換えないための安全側 default)
#
# opt-in で Docker でも層 2 を有効にしたい場合のみ XANGI_ENV_PATH を指定:
#   docker-compose.yml で .env を volume mount + XANGI_ENV_PATH を設定する。例:
#     volumes:
#       - ./.env:/workspace/.env:rw
#     environment:
#       - XANGI_ENV_PATH=/workspace/.env
#
# XANGI_ENV_PATH=/workspace/.env

# ========================================
# インスタンス間チャット (inter-instance-chat) 設定
# ========================================
# 同マシン上の複数 xangi インスタンス（ホスト直 + Docker 混在）が、
# Discord/Slack を介さず軽量にメッセージをやり取りするコア機能。
# 共有ディレクトリ配下の per-instance JSONL を相互 watch する方式。
# Web UI: WEB_CHAT_ENABLED=true で http://<host>:<WEB_CHAT_PORT>/ (web-chat) に統合表示。
# 全インスタンスを時系列で見たいときは /inter-chat も利用可
# CLI: xangi-cmd inter_chat_send/tail/clear/list/config
# 詳細は docs/inter-instance-chat.md 参照。

# Optional: enable inter-instance chat (default: false)
# INTER_INSTANCE_CHAT_ENABLED=false

# Optional: shared directory (default: /tmp/xangi-chat)
# Docker でも同パスを bind mount すれば混在運用可能。
# /tmp は OS 再起動で消える tmpfs 想定。
# INTER_INSTANCE_CHAT_DIR=/tmp/xangi-chat

# Optional: message TTL seconds (default: 3600 = 1h)
# INTER_INSTANCE_CHAT_TTL_SEC=3600

# Optional: physical compaction interval seconds (default: 600 = 10min)
# INTER_INSTANCE_CHAT_COMPACT_INTERVAL_SEC=600

# Optional: file-watch polling fallback (default: false)
# Mac/Win Docker Desktop の inotify が信頼できない場合 true に。
# Linux native / WSL2 native は false で OK。
# INTER_INSTANCE_CHAT_USE_POLLING=false

# 自走モード（auto-talk）の発話間隔（秒、デフォ 10〜45 のランダム）
# 自走 ON の web セッションごとに、min〜max のランダム間隔で agent を叩いて発話を生成する
# INTER_INSTANCE_CHAT_AUTOTALK_MIN_SEC=10
# INTER_INSTANCE_CHAT_AUTOTALK_MAX_SEC=45

# 自走モードプロンプトに含める直近 inter-chat メッセージ数（デフォ 20）
# INTER_INSTANCE_CHAT_AUTOTALK_HISTORY_LIMIT=20

# ========================================
# ワークスペース hooks (Stop hook)
# ========================================
# エージェントループのターン終了時に外部検証プロセス (hook) を挟む。
# 契約は Claude Code / Codex CLI の Stop hook と互換 (stdin JSON、
# exit 0 + {"decision":"block","reason":"..."} または exit 2 + stderr)。
# block されたらフィードバックを LLM に注入して 1 回だけ継続ラウンドを回す。
# 対応: Stop イベントのみ / local-llm バックエンドのみ。
# ツール無効モード (chat) ではゲート自体を自動スキップする。
# hook 側の異常 (timeout / 不正出力) はすべて素通り (フェイルオープン)。
# 詳細: docs/usage.md「ワークスペース hooks（Stop hook）」セクション

# 有効/無効 (default: true)。ワークスペースに hooks/hooks.json が無ければ no-op。
# false はキルスイッチ (hooks.json を残したまま一時停止)
# XANGI_HOOKS_ENABLED=true

# hooks 設定ファイルのパス (default: <workspace>/hooks/hooks.json)
# XANGI_HOOKS_FILE=

# ========================================
# Tool Trajectory Logger (observability)
# ========================================
# Local LLM の tool 使用挙動 (drift / loop / tool_search 採用ミス) を観測するため、
# 5+1 機構 (loop / 冪等キャッシュ / streaming hold buffer / pseudo tool_call rescue /
# context prune) の発火タイミングを構造化 jsonl で記録する。
# 既存 transcript-logger (logs/sessions/) とは独立に logs/tool-trajectory/<appSessionId>.jsonl
# へ append され、session restore とは完全分離されている。
#
# 全 event 共通 fields: ts / event_id / kind / schema_version=1 / appSessionId /
#   turn_index / seq / platform / backend / model / channelId_hash / round
# kind: session_start / tool_call / tool_search / drift_rescue / loop_detected / runner_event
#
# OSS 公開前提のため強制 sanitize:
#  - secret 系 key (token/apiKey/bearer/...) → [REDACTED_SECRET]
#  - Discord channelId / userId / LINE userId → salt 付き sha256 hash (12 字)
#  - 絶対 path home prefix → $HOME に置換
#  - 長文 args/result → head/tail 方式で切り詰め
#
# 詳細: docs/usage.md「Tool Trajectory Logger」セクション

# 有効/無効 (default: true)。false で完全 no-op、ファイル作成もしない
# XANGI_TOOL_TRAJECTORY_LOG=true

# Discord/LINE ID hash 用 salt。未指定なら起動毎にランダム生成
# (同セッション内で同 ID は同 hash になる、プロセス跨ぎで相関を追いたい場合のみ固定値を指定)
# TOOL_TRAJECTORY_LOG_HASH_SALT=

# args 切り詰め上限 (default: 8192 chars)
# TOOL_TRAJECTORY_LOG_MAX_ARGS_CHARS=8192

# tool result 切り詰め上限 (default: 16384 chars)
# TOOL_TRAJECTORY_LOG_MAX_RESULT_CHARS=16384

# 古いファイル削除の TTL (default: 未設定 = 削除しない)
# 観察データを残す前提のため default では削除しない。容量が気になる場合のみ
# 明示指定する (例: 14)
# TOOL_TRAJECTORY_LOG_RETENTION_DAYS=

# logs/tool-trajectory 全体のサイズ上限 MB (default: 未設定 = 上限なし)
# 設定時は超えた分を古いファイルから削除 (例: 200)
# TOOL_TRAJECTORY_LOG_SIZE_CAP_MB=
