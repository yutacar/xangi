{
  "name": "xangi-dev",
  "version": "0.1.0",
  "description": "Discord bot with Claude Code CLI integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "xangi": "./bin/xangi",
    "xangi-cmd": "./bin/xangi-cmd"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "xangi": "node dist/cli/xangi.js",
    "xangi-cmd": "node --env-file=.env dist/cli/xangi-cmd.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "{src,tests}/**/*.ts": [
      "bash -c 'unset DATA_DIR WORKSPACE_PATH GIT_INDEX_FILE GIT_DIR GIT_WORK_TREE; npx vitest run'",
      "bash -c 'npx tsc --noEmit'"
    ]
  },
  "keywords": [
    "ai",
    "agent",
    "discord",
    "claude-code"
  ],
  "author": "karaage",
  "license": "MIT",
  "dependencies": {
    "@line/bot-sdk": "^11.2.0",
    "@octokit/auth-app": "^8.2.0",
    "@slack/bolt": "^4.7.3",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "grammy": "^1.45.1",
    "node-cron": "^4.6.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^22.20.1",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "undici": "6.27.0"
  }
}
