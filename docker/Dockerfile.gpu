# Stage 1: Build (using Node.js for TypeScript compilation)
FROM node:22-slim AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY tsconfig.json ./
COPY src/ ./src/
COPY web/ ./web/
RUN npm run build

# Stage 2: Production (GPU version with CUDA + Node.js + uv + Python + PyTorch)
# Reference: https://github.com/karaage0703/karaagebot (sandbox Dockerfile)
# Reference: https://zenn.dev/karaage0703/articles/985ddbd8fa15d3
FROM nvidia/cuda:13.1.1-cudnn-runtime-ubuntu24.04

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install Node.js 22, system dependencies, and GitHub CLI
RUN apt-get update && apt-get install -y \
    curl \
    git \
    ca-certificates \
    gnupg \
    python3 \
    python3-pip \
    ffmpeg \
    jq \
    fonts-noto-cjk \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list > /dev/null \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y nodejs gh \
    && rm -rf /var/lib/apt/lists/*

# Copy uv binary from official image
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Install PyTorch with CUDA support via uv (pyproject.toml + lockfile)
COPY gpu-pyproject.toml /opt/gpu-env/pyproject.toml
RUN cd /opt/gpu-env && uv sync --frozen --no-dev 2>/dev/null \
    || cd /opt/gpu-env && uv sync --no-dev

WORKDIR /app

# Copy package files and install production dependencies
COPY package*.json ./
RUN npm ci --omit=dev --ignore-scripts

# Copy built files from builder stage
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/web ./web

# Copy xangi-cmd wrapper (tool-server CLI client)
COPY bin/ ./bin/
RUN chmod +x /app/bin/xangi-cmd

# Install Codex CLI globally (as root)
RUN npm install -g @openai/codex

# Use existing ubuntu user (UID 1000, matches host user for volume permissions)
# Reference: karaagebot Dockerfile uses ubuntu user the same way
RUN mkdir -p /home/ubuntu/.config/gh /home/ubuntu/.codex /home/ubuntu/.local/bin /home/ubuntu/.local/share/uv \
    && chown -R ubuntu:ubuntu /home/ubuntu

# Switch to ubuntu user for CLI installations
USER ubuntu

# Install Claude Code CLI
RUN curl -fsSL https://claude.ai/install.sh | bash

# Install CLI tools via uv tool
RUN uv tool install yt-dlp && \
    uv tool install youtube-transcript-api

# Add Claude, Codex, uv tools, GPU venv, and xangi-cmd to PATH
ENV PATH="/home/ubuntu/.local/bin:/opt/gpu-env/.venv/bin:/app/bin:${PATH}"

# Make CUDA libraries visible
ENV LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH}"

# Default command
CMD ["node", "dist/index.js"]
