# Stage 1: Build
FROM node:22-slim AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY tsconfig.json ./
COPY src/ ./src/
COPY web/ ./web/
RUN npm run build

# Stage 2: Production (Full version with uv + Python)
FROM node:22-slim

# Install dependencies for Claude Code CLI, GitHub CLI, Python, and xangi-cmd (jq)
RUN apt-get update && apt-get install -y \
    curl \
    git \
    ca-certificates \
    jq \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Copy uv binary from official image
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Install Python via uv
RUN uv python install 3.12

WORKDIR /app

# Copy package files and install production dependencies
COPY package*.json ./
RUN npm ci --omit=dev --ignore-scripts

# Copy built files from builder stage
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/web ./web

# Copy xangi-cmd wrapper (tool-server CLI client)
COPY bin/ ./bin/
RUN chmod +x /app/bin/xangi-cmd

# Install Codex CLI globally (as root)
RUN npm install -g @openai/codex

# Create directories for node user. The named volume mounted at /home/node/.codex
# inherits the ownership from this image directory on first creation.
RUN mkdir -p /home/node/.config/gh /home/node/.codex \
    && chown -R node:node /home/node/.config /home/node/.codex

# Switch to node user for Claude Code CLI installation
USER node

# Install Claude Code CLI as node user
RUN curl -fsSL https://claude.ai/install.sh | bash

# Add Claude, Codex, uv, and xangi-cmd to PATH
ENV PATH="/home/node/.local/bin:/root/.local/bin:/app/bin:${PATH}"

# Default command
CMD ["node", "dist/index.js"]
